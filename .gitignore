# dependencies
node_modules/

# build output
dist/
out/
.turbo/
*.tsbuildinfo

# electron packaging
apps/desktop/release/
apps/desktop/out/

# electron-vite compiled-config cache
**/electron.vite.config.*.mjs

# os / editor
.DS_Store
*.log
.vscode/*
!.vscode/extensions.json
.idea/

# local tool installs (runtime-installed tools live in userData, never committed)
.toolbox-cache/

# resolved catalog — generated by scripts/resolve-catalog.mjs, published to the
# `catalog-data` branch by the resolve-catalog workflow; never committed here.
registry/resolved.json

# local agent / editor config (never committed)
.claude/

# user-created presentation folders (live in the source tree during dev authoring)
apps/tools/presenter/src/presentations/u-*/

# AI-grown block library (saved by Claude across sessions)
apps/tools/presenter/blocks-user/
