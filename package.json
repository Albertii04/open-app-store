{
  "name": "alberts-toolbox",
  "version": "0.3.0",
  "private": true,
  "description": "Open-source Electron toolbox: a shell that hosts independent web-based tools, each sandboxed, with a capability broker and a git-based marketplace.",
  "license": "MIT",
  "packageManager": "pnpm@10.4.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@toolbox/shell...",
    "dev:presenter": "turbo run dev --filter=@toolbox/tool-presenter",
    "build": "turbo run build",
    "build:tools": "turbo run build --filter=./tools/*",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "shell": "pnpm --filter @toolbox/shell start",
    "package": "pnpm --filter @toolbox/shell package"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  }
}
