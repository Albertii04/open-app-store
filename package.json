{
  "name": "open-app-store",
  "version": "0.3.2",
  "private": true,
  "description": "Open-source Electron toolbox: a shell that hosts independent web-based tools, each sandboxed, with a capability broker and a git-based marketplace.",
  "license": "MIT",
  "packageManager": "pnpm@10.4.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@openappstore/desktop...",
    "dev:presenter": "turbo run dev --filter=@openappstore/presenter",
    "build": "turbo run build",
    "build:tools": "turbo run build --filter=./apps/tools/*",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "shell": "pnpm --filter @openappstore/desktop start",
    "package": "pnpm --filter @openappstore/desktop package"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
