    "@vue/tsconfig": "^0.9.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "electron-window-state": "^5.0.3",
    "tailwindcss": "^4",
