{
  "name": "@toolbox/shell",
  "version": "0.1.0",
  "description": "Electron shell that hosts sandboxed web tools with a capability broker.",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && vue-tsc --noEmit -p tsconfig.web.json",
    "lint": "tsc --noEmit -p tsconfig.node.json",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@toolbox/sdk": "workspace:*",
    "@toolbox/tool-host": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.7.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "~5.7.2",
    "vite": "^5.4.11",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
